# =====================================================
# VERIX SOUL OS - Buildroot Minimal Configuration
# Objetivo: Sistema ultra-ligero, solo Rust como init
# Arquitectura: x86_64 (compatible con VMs)
# =====================================================

# Arquitectura objetivo
BR2_x86_64=y
BR2_x86_corei7=y

# Toolchain: usamos la interna de Buildroot con musl (estatico, sin glibc)
BR2_TOOLCHAIN_BUILDROOT_MUSL=y
BR2_TOOLCHAIN_BUILDROOT_CXX=y

# Kernel de Linux - version minima estable
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_LATEST_LTS_VERSION=y
BR2_LINUX_KERNEL_USE_DEFCONFIG=y
BR2_LINUX_KERNEL_DEFCONFIG="x86_64"

# --- CRITICO: No usamos systemd ni sysvinit ---
# Nuestro binario Rust ES el init (PID 1)
BR2_INIT_NONE=y

# --- NO instalamos BusyBox (ahorra ~800KB) ---
# Sin shell, sin comandos de usuario. Solo el alma.
BR2_PACKAGE_BUSYBOX=n

# --- Sistema de archivos: tmpfs en RAM ---
# El sistema completo vive en RAM. Inmutable. Indestructible.
BR2_TARGET_ROOTFS_CPIO=y
BR2_TARGET_ROOTFS_CPIO_GZIP=y

# Eliminar completamente la documentacion
BR2_PACKAGE_OVERRIDE_FILE=""
BR2_PACKAGE_HOST_DOSFSTOOLS=n
BR2_PACKAGE_HOST_MTOOLS=n

# Red: soporte basico para sincronizacion del alma
BR2_PACKAGE_IFUPDOWN_SCRIPTS=n
BR2_SYSTEM_DHCP="eth0"

# Overlay con nuestro binario Rust como /sbin/init
BR2_ROOTFS_OVERLAY="overlay"

# --- Optimizaciones de tamano ---
BR2_STRIP_strip=y
BR2_OPTIMIZE_S=y
BR2_ENABLE_LOCALE=n
BR2_ENABLE_LOCALE_PURGE=y
BR2_GENERATE_LOCALE=""

# Sin soporte para NLS (National Language Support) para reducir tamano
BR2_NEEDS_HOST_UTF8_LOCALE=n

# Timezone data minima
BR2_PACKAGE_TZDATA=n

# Sin pam, sin login, sin getty
BR2_PACKAGE_SHADOW=n
BR2_TARGET_GENERIC_GETTY=n
